# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=cinesense

# JWT Secret (minimum 32 characters)
JWT_SECRET=your_jwt_secret_key_here_make_it_at_least_32_characters_long

# API Keys (REQUIRED)
# Get Gemini API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# Get TMDB API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Redis Configuration (Optional - for caching)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DISABLED=false

# Logging
LOG_LEVEL=info

# Rate Limiting (Optional - for development)
# Set to 'true' to disable rate limiting in development
DISABLE_RATE_LIMIT=false
